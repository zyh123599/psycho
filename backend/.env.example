OPENAI_BASE_URL=https://your-openai-compatible-endpoint.example/v1
OPENAI_API_KEY=replace-me
OPENAI_MODEL=gpt-5.6-sol
OPENAI_API_MODE=chat_completions

# 仅当测试环境不得不使用明文 HTTP 中转站时才设为 true。
ALLOW_INSECURE_OPENAI_BASE_URL=false

ENVIRONMENT=development
# 逗号分隔。开发环境留空表示关闭后端 API key 鉴权；生产环境必须配置。
APP_API_KEYS=
CORS_ORIGINS=http://localhost:4173,http://localhost:4174,http://localhost:8100,http://127.0.0.1:4173,http://127.0.0.1:8100,capacitor://localhost,https://localhost

OPENAI_TIMEOUT_SECONDS=120
OPENAI_MAX_RETRIES=2
OPENAI_MAX_OUTPUT_TOKENS=3200
OPENAI_IMAGE_DETAIL=auto

MAX_REQUEST_BYTES=26214400
MAX_PAYLOAD_JSON_BYTES=131072
MAX_TEXT_CHARS=30000
MAX_IMAGES=4
MAX_IMAGE_BYTES=8388608
MAX_IMAGE_PIXELS=20000000
MAX_IMAGE_DIMENSION=2048
MAX_CONCURRENT_ANALYSES=8
